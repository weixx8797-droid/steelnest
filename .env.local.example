# ====== SteelNest 环境变量配置 ======
# 复制这个文件为 .env.local，然后填入你的真实密钥

# Stripe 密钥（从 https://dashboard.stripe.com/apikeys 获取）
# 开发阶段用 "Secret key" 以 sk_test_ 开头的
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# PayPal 密钥（从 https://developer.paypal.com 获取）
# 开发阶段用 Sandbox 密钥
NEXT_PUBLIC_PAYPAL_CLIENT_ID=sb-xxxxxxxxxxxx
PAYPAL_SECRET_KEY=xxxxxxxxxxxx

# 网站域名（本地开发用下面这个，上线后改成真实域名）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
